# Database
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=unimart
DATABASE_URL=postgresql://postgres:password@localhost:5432/unimart

# Delivery fee shown at checkout (must match config.js DELIVERY_FEE)
DELIVERY_FEE=10

# Google Gemini — required for AI recommendations
GEMINI_API_KEY=

# EmailJS — optional, set in config.js on the frontend instead
# RAZORPAY — set RAZORPAY_KEY in config.js for wallet top-ups

# Admin Credentials
ADMIN_EMAIL=
ADMIN_PASSWORD=
